digraph wiring {
  rankdir=LR;
  node [fontname="monospace", fontsize=10];
  edge [fontname="monospace", fontsize=9];

  mcu [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightgrey"><b>MSPM0G3507</b></td></tr><tr><td port="motorL_pwm" align="left">PA0:PWM (motorL_pwm)</td></tr><tr><td port="motorL_in1" align="left">PA4:GPIO (motorL_in1)</td></tr><tr><td port="motorL_in2" align="left">PA5:GPIO (motorL_in2)</td></tr><tr><td port="motorR_pwm" align="left">PA1:PWM (motorR_pwm)</td></tr><tr><td port="motorR_in1" align="left">PA6:GPIO (motorR_in1)</td></tr><tr><td port="motorR_in2" align="left">PA7:GPIO (motorR_in2)</td></tr><tr><td port="motor_stby" align="left">PB13:GPIO (motor_stby)</td></tr><tr><td port="servo_pan" align="left">PA2:PWM (servo_pan)</td></tr><tr><td port="encL_a" align="left">PA8:QEI_A (encL_a)</td></tr><tr><td port="encL_b" align="left">PA9:QEI_B (encL_b)</td></tr><tr><td port="encR_a" align="left">PA10:QEI_A (encR_a)</td></tr><tr><td port="encR_b" align="left">PA11:QEI_B (encR_b)</td></tr><tr><td port="k230_tx" align="left">PA12:UART_TX (k230_tx)</td></tr><tr><td port="k230_rx" align="left">PA13:UART_RX (k230_rx)</td></tr><tr><td port="log_tx" align="left">PA14:UART_TX (log_tx)</td></tr><tr><td port="i2c_sda" align="left">PB0:I2C_SDA (i2c_sda)</td></tr><tr><td port="i2c_scl" align="left">PB1:I2C_SCL (i2c_scl)</td></tr><tr><td port="gray0" align="left">PB2:ADC (gray0)</td></tr><tr><td port="gray1" align="left">PB3:ADC (gray1)</td></tr><tr><td port="gray2" align="left">PB4:ADC (gray2)</td></tr><tr><td port="gray3" align="left">PB5:ADC (gray3)</td></tr><tr><td port="gray4" align="left">PB6:ADC (gray4)</td></tr><tr><td port="gray5" align="left">PB7:ADC (gray5)</td></tr><tr><td port="gray6" align="left">PB8:ADC (gray6)</td></tr><tr><td port="gray7" align="left">PB9:ADC (gray7)</td></tr><tr><td port="vbat_sense" align="left">PB10:ADC (vbat_sense)</td></tr><tr><td port="button_start" align="left">PB14:GPIO (button_start)</td></tr><tr><td port="button_mode" align="left">PB15:GPIO (button_mode)</td></tr><tr><td port="buzzer" align="left">PA17:GPIO (buzzer)</td></tr><tr><td port="swd_io" align="left">PA20:SWD_IO (swd_io)</td></tr><tr><td port="swd_clk" align="left">PA21:SWD_CLK (swd_clk)</td></tr></table>>];
  m_TB6612_1 [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>TB6612#1</b></td></tr><tr><td port="motorL_pwm" align="left">PWMA</td></tr><tr><td port="motorL_in1" align="left">AIN1</td></tr><tr><td port="motorL_in2" align="left">AIN2</td></tr><tr><td port="motorR_pwm" align="left">PWMB</td></tr><tr><td port="motorR_in1" align="left">BIN1</td></tr><tr><td port="motorR_in2" align="left">BIN2</td></tr><tr><td port="motor_stby" align="left">STBY</td></tr></table>>];
  mcu:"motorL_pwm" -> m_TB6612_1:"motorL_pwm" [label="PWM"];
  mcu:"motorL_in1" -> m_TB6612_1:"motorL_in1" [label="GPIO"];
  mcu:"motorL_in2" -> m_TB6612_1:"motorL_in2" [label="GPIO"];
  mcu:"motorR_pwm" -> m_TB6612_1:"motorR_pwm" [label="PWM"];
  mcu:"motorR_in1" -> m_TB6612_1:"motorR_in1" [label="GPIO"];
  mcu:"motorR_in2" -> m_TB6612_1:"motorR_in2" [label="GPIO"];
  mcu:"motor_stby" -> m_TB6612_1:"motor_stby" [label="GPIO"];
  m_servo [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>servo</b></td></tr><tr><td port="servo_pan" align="left">SIG</td></tr></table>>];
  mcu:"servo_pan" -> m_servo:"servo_pan" [label="PWM"];
  m_encoderL [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>encoderL</b></td></tr><tr><td port="encL_a" align="left">A</td></tr><tr><td port="encL_b" align="left">B</td></tr></table>>];
  mcu:"encL_a" -> m_encoderL:"encL_a" [label="QEI_A"];
  mcu:"encL_b" -> m_encoderL:"encL_b" [label="QEI_B"];
  m_encoderR [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>encoderR</b></td></tr><tr><td port="encR_a" align="left">A</td></tr><tr><td port="encR_b" align="left">B</td></tr></table>>];
  mcu:"encR_a" -> m_encoderR:"encR_a" [label="QEI_A"];
  mcu:"encR_b" -> m_encoderR:"encR_b" [label="QEI_B"];
  m_K230 [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>K230</b></td></tr><tr><td port="k230_tx" align="left">RXD</td></tr><tr><td port="k230_rx" align="left">TXD</td></tr></table>>];
  mcu:"k230_tx" -> m_K230:"k230_tx" [label="UART_TX"];
  mcu:"k230_rx" -> m_K230:"k230_rx" [label="UART_RX"];
  m_USB_TTL [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>USB-TTL</b></td></tr><tr><td port="log_tx" align="left">RXD</td></tr></table>>];
  mcu:"log_tx" -> m_USB_TTL:"log_tx" [label="UART_TX"];
  m_OLED_IMU [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>OLED+IMU</b></td></tr><tr><td port="i2c_sda" align="left">SDA</td></tr><tr><td port="i2c_scl" align="left">SCL</td></tr></table>>];
  mcu:"i2c_sda" -> m_OLED_IMU:"i2c_sda" [label="I2C_SDA"];
  mcu:"i2c_scl" -> m_OLED_IMU:"i2c_scl" [label="I2C_SCL"];
  m_8ch_grayscale [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>8ch-grayscale</b></td></tr><tr><td port="gray0" align="left">CH0</td></tr><tr><td port="gray1" align="left">CH1</td></tr><tr><td port="gray2" align="left">CH2</td></tr><tr><td port="gray3" align="left">CH3</td></tr><tr><td port="gray4" align="left">CH4</td></tr><tr><td port="gray5" align="left">CH5</td></tr><tr><td port="gray6" align="left">CH6</td></tr><tr><td port="gray7" align="left">CH7</td></tr></table>>];
  mcu:"gray0" -> m_8ch_grayscale:"gray0" [label="ADC"];
  mcu:"gray1" -> m_8ch_grayscale:"gray1" [label="ADC"];
  mcu:"gray2" -> m_8ch_grayscale:"gray2" [label="ADC"];
  mcu:"gray3" -> m_8ch_grayscale:"gray3" [label="ADC"];
  mcu:"gray4" -> m_8ch_grayscale:"gray4" [label="ADC"];
  mcu:"gray5" -> m_8ch_grayscale:"gray5" [label="ADC"];
  mcu:"gray6" -> m_8ch_grayscale:"gray6" [label="ADC"];
  mcu:"gray7" -> m_8ch_grayscale:"gray7" [label="ADC"];
  m_divider [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>divider</b></td></tr><tr><td port="vbat_sense" align="left">?</td></tr></table>>];
  mcu:"vbat_sense" -> m_divider:"vbat_sense" [label="ADC"];
  m_button [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>button</b></td></tr><tr><td port="button_start" align="left">START</td></tr><tr><td port="button_mode" align="left">MODE</td></tr></table>>];
  mcu:"button_start" -> m_button:"button_start" [label="GPIO"];
  mcu:"button_mode" -> m_button:"button_mode" [label="GPIO"];
  m_buzzer [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>buzzer</b></td></tr><tr><td port="buzzer" align="left">SIG</td></tr></table>>];
  mcu:"buzzer" -> m_buzzer:"buzzer" [label="GPIO"];
  m_debugger [shape=plaintext, label=<<table border="1" cellborder="0" cellspacing="0"><tr><td bgcolor="lightyellow"><b>debugger</b></td></tr><tr><td port="swd_io" align="left">SWDIO</td></tr><tr><td port="swd_clk" align="left">SWCLK</td></tr></table>>];
  mcu:"swd_io" -> m_debugger:"swd_io" [label="SWD_IO"];
  mcu:"swd_clk" -> m_debugger:"swd_clk" [label="SWD_CLK"];
}